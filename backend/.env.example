# ===== LLM 提供方 =====
# spark         讯飞星火 HTTP（OpenAI 兼容）—— 赛题要求的讯飞工具，正式演示用这个
# openai_compat OpenAI 兼容接口（如 Claude 中转站），开发期可用
# fake          离线/占位，无需网络，返回内置内容
LLM_PROVIDER=spark

# --- 讯飞星火（LLM_PROVIDER=spark）---
# LLM_BASE_URL 留空即用星火默认端点 https://spark-api-open.xf-yun.com/v1
LLM_BASE_URL=
# LLM_API_KEY 填星火控制台「http服务接口认证信息」里的 APIPassword（单个字符串，不是 APIKey:APISecret）
LLM_API_KEY=填入你的APIPassword
# LLM_MODEL 选模型版本：lite(免费) / generalv3(Pro) / pro-128k / generalv3.5(Max) / max-32k / 4.0Ultra
LLM_MODEL=lite

# --- OpenAI 兼容 / Claude 中转（LLM_PROVIDER=openai_compat）时改用下面这组 ---
# LLM_BASE_URL=https://your-relay-host/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=claude-3-5-sonnet

# 留空则用内存画像仓储；设为文件名启用 SQLite 持久化
DB_PATH=profiles.db
